# ============================================
# QA Hub 환경설정 파일
# ============================================
# cp .env.example .env 후 본인 값 입력
# ⚠️ .env 파일은 절대 Git에 커밋하지 마세요!
# ============================================

# Jira QA 대시보드 자동 생성 설정
# Jira API 토큰 발급: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your-jira-api-token
JIRA_BASE_URL=https://musinsa-oneteam.atlassian.net
BUG_PROJECT=OFFSYSM

# ============================================
# UI 자동화 테스트 설정
# ============================================

# Okta 계정 (Self-POS / mPOS 로그인용)
OKTA_EMAIL=your-email@musinsa.com
OKTA_PASSWORD=your-okta-password

# PDP 고객 계정 (로그인 테스트용)
CUSTOMER_EMAIL=test-customer@example.com
CUSTOMER_PASSWORD=test-customer-password

# Slack 알림
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_CHANNEL=#o4o-qa-automation
